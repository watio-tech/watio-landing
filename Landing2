<!DOCTYPE html>
<html lang="es-AR" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Watio ⚡️ | El CPMS diseñado para LATAM</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        watio: {
                            cyan: '#00E5FF',
                            charcoal: '#1a1a1b',
                            dark: '#0f172a'
                        }
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .cyan-shadow { box-shadow: 0 4px 20px rgba(0, 229, 255, 0.4); }
        .lang-btn { cursor: pointer; transition: all 0.2s; }
    </style>
</head>
<body class="bg-white text-watio-charcoal antialiased selection:bg-watio-cyan selection:text-watio-charcoal">

    <!-- Navegación -->
    <nav class="fixed w-full bg-white/90 backdrop-blur-md z-50 border-b border-gray-100">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <!-- Logo -->
                <img src="logo.png" alt="Watio Logo" class="h-10 object-contain" onerror="this.outerHTML='<span class=\'text-2xl font-black tracking-tighter\'>Watio<span class=\'text-watio-cyan\'>.</span></span>'">
            </div>
            <div class="flex items-center gap-6">
                <!-- Switcher de Idiomas -->
                <div class="flex space-x-2 text-sm font-semibold text-gray-400">
                    <span class="lang-btn opacity-50 hover:text-watio-charcoal" data-lang="pt-BR" onclick="setLanguage('pt-BR')">PT</span>
                    <span>|</span>
                    <span class="lang-btn opacity-50 hover:text-watio-charcoal" data-lang="es-AR" onclick="setLanguage('es-AR')">ES</span>
                </div>
                <a href="mailto:jvolcanes@watio.com.ar" class="hidden md:block bg-watio-cyan text-watio-charcoal font-bold py-2 px-6 rounded-lg hover:bg-cyan-400 transition-colors shadow-sm" data-i18n="navCTA">
                    Solicitar Demo
                </a>
            </div>
        </div>
    </nav>

    <!-- Sección 1: El Hero -->
    <header class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
        <div class="max-w-7xl mx-auto px-6 grid lg:grid-cols-2 gap-12 items-center">
            
            <!-- Copy Principal -->
            <div class="relative z-10">
                <span class="text-gray-400 font-semibold tracking-wider text-sm uppercase mb-4 block" data-i18n="heroPre">
                    EL CPMS DISEÑADO PARA LATAM
                </span>
                <h1 class="text-5xl lg:text-6xl font-black leading-tight mb-6 text-watio-charcoal" data-i18n="heroTitle">
                    Resolvé la carga de vehículos eléctricos en tu edificio sin complicar las expensas.
                </h1>
                <p class="text-lg text-gray-600 mb-8 leading-relaxed max-w-xl" data-i18n="heroSub">
                    Watio es el sistema operativo que automatiza el cobro, la medición y la gestión de cargadores en consorcios. Transparencia total para los vecinos, cero fricción para la administración.
                </p>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="mailto:jvolcanes@watio.com.ar" class="bg-watio-cyan text-watio-charcoal text-center font-bold text-lg py-4 px-8 rounded-xl hover:bg-cyan-400 transition-all transform hover:-translate-y-1 cyan-shadow" data-i18n="heroCTA">
                        Solicitar Demo Gratuita
                    </a>
                </div>
            </div>

            <!-- Visual: Mockup estilo Apple -->
            <div class="relative lg:ml-10">
                <div class="absolute -inset-1 bg-gradient-to-r from-watio-cyan to-blue-500 rounded-2xl blur opacity-20"></div>
                <div class="relative bg-white rounded-2xl shadow-2xl border border-gray-100 p-6">
                    <!-- Faux Browser/App Header -->
                    <div class="flex items-center justify-between border-b border-gray-100 pb-4 mb-6">
                        <div class="flex gap-2">
                            <div class="w-3 h-3 rounded-full bg-red-400"></div>
                            <div class="w-3 h-3 rounded-full bg-amber-400"></div>
                            <div class="w-3 h-3 rounded-full bg-green-400"></div>
                        </div>
                        <span class="text-xs font-semibold text-gray-400" data-i18n="mockupTitle">Panel del Administrador</span>
                    </div>
                    
                    <!-- Faux Dashboard Content -->
                    <div class="space-y-6">
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="font-semibold" data-i18n="mockupUnit">Cochera 12 - Unidad 4B</span>
                                <span class="text-gray-500">240 kWh</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-3">
                                <div class="bg-watio-cyan h-3 rounded-full" style="width: 75%"></div>
                            </div>
                        </div>
                        
                        <div>
                            <div class="flex justify-between text-sm mb-2">
                                <span class="font-semibold" data-i18n="mockupUnit2">Cochera 05 - Unidad 1A</span>
                                <span class="text-gray-500">180 kWh</span>
                            </div>
                            <div class="w-full bg-gray-100 rounded-full h-3">
                                <div class="bg-watio-cyan h-3 rounded-full" style="width: 45%"></div>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-gray-100 flex justify-between items-center">
                            <span class="text-sm text-gray-500" data-i18n="mockupTotal">Total a liquidar (Mes)</span>
                            <span class="text-xl font-bold text-watio-charcoal">$ 85.400</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Sección 2: El Problema -->
    <section class="py-24 bg-gray-50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center max-w-3xl mx-auto mb-16">
                <h2 class="text-3xl md:text-4xl font-bold text-watio-charcoal mb-4" data-i18n="probTitle">
                    El futuro eléctrico ya llegó al garaje. ¿Está preparado el consorcio?
                </h2>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <!-- Card 1 -->
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-red-50 text-red-500 rounded-xl flex items-center justify-center text-xl mb-6">
                        <i class="fas fa-plug-circle-xmark"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3" data-i18n="prob1Title">Adiós al "Robo" de Energía</h3>
                    <p class="text-gray-600 leading-relaxed" data-i18n="prob1Desc">Evitá conflictos. Terminá con la incertidumbre de quién paga por la luz que consume cada vehículo en las cocheras.</p>
                </div>

                <!-- Card 2 -->
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-orange-50 text-orange-500 rounded-xl flex items-center justify-center text-xl mb-6">
                        <i class="fas fa-calculator"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3" data-i18n="prob2Title">Cero Cálculos Manuales</h3>
                    <p class="text-gray-600 leading-relaxed" data-i18n="prob2Desc">Olvidate de planillas de Excel complejas. El sistema mide el consumo exacto de cada usuario de forma individual.</p>
                </div>

                <!-- Card 3 -->
                <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition-shadow">
                    <div class="w-12 h-12 bg-watio-cyan/20 text-watio-charcoal rounded-xl flex items-center justify-center text-xl mb-6">
                        <i class="fas fa-laptop-code"></i>
                    </div>
                    <h3 class="text-xl font-bold mb-3" data-i18n="prob3Title">Gestión Centralizada</h3>
                    <p class="text-gray-600 leading-relaxed" data-i18n="prob3Desc">Un único panel para monitorear todos los puntos de carga del edificio, sin importar la marca del cargador.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Sección 3: La Solución -->
    <section class="py-24 bg-white">
        <div class="max-w-7xl mx-auto px-6">
            <h2 class="text-3xl md:text-4xl font-bold text-center text-watio-charcoal mb-16" data-i18n="solTitle">
                Infraestructura inteligente, cobro automatizado.
            </h2>

            <div class="grid md:grid-cols-3 gap-12 relative">
                <!-- Línea conectora (Desktop) -->
                <div class="hidden md:block absolute top-8 left-[10%] right-[10%] h-1 bg-gray-100 -z-10">
                    <div class="h-full bg-watio-cyan w-full"></div>
                </div>

                <!-- Paso 1 -->
                <div class="text-center">
                    <div class="w-16 h-16 mx-auto bg-watio-charcoal text-watio-cyan text-2xl font-black rounded-full flex items-center justify-center mb-6 shadow-lg">1</div>
                    <h3 class="text-xl font-bold mb-3" data-i18n="sol1Title">Medición Precisa</h3>
                    <p class="text-gray-600" data-i18n="sol1Desc">Nos integramos con los cargadores de tu edificio para leer el consumo en tiempo real.</p>
                </div>

                <!-- Paso 2 -->
                <div class="text-center">
                    <div class="w-16 h-16 mx-auto bg-watio-charcoal text-watio-cyan text-2xl font-black rounded-full flex items-center justify-center mb-6 shadow-lg">2</div>
                    <h3 class="text-xl font-bold mb-3" data-i18n="sol2Title">Cobro Directo</h3>
                    <p class="text-gray-600" data-i18n="sol2Desc">El vecino paga exactamente lo que consume a través de nuestra plataforma (integración con métodos de pago locales).</p>
                </div>

                <!-- Paso 3 -->
                <div class="text-center">
                    <div class="w-16 h-16 mx-auto bg-watio-charcoal text-watio-cyan text-2xl font-black rounded-full flex items-center justify-center mb-6 shadow-lg">3</div>
                    <h3 class="text-xl font-bold mb-3" data-i18n="sol3Title">Liquidación Transparente</h3>
                    <p class="text-gray-600" data-i18n="sol3Desc">El consorcio recibe el dinero de la energía consumida directamente en su cuenta, listo para descontar de los gastos comunes.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Sección 4: El Cierre (CTA) -->
    <section class="py-24 bg-watio-charcoal text-white text-center">
        <div class="max-w-4xl mx-auto px-6">
            <h2 class="text-4xl md:text-5xl font-black mb-6" data-i18n="ctaTitle">
                La movilidad eléctrica no tiene por qué ser un dolor de cabeza.
            </h2>
            <p class="text-xl text-gray-400 mb-10" data-i18n="ctaSub">
                Dejanos la infraestructura a nosotros. Vos enfocate en administrar.
            </p>
            <a href="mailto:jvolcanes@watio.com.ar" class="inline-block bg-watio-cyan text-watio-charcoal font-bold text-xl py-5 px-10 rounded-xl hover:bg-cyan-400 transition-all transform hover:scale-105 shadow-2xl" data-i18n="ctaBtn">
                Hablar con un Asesor
            </a>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-watio-dark py-12 text-center text-gray-500 text-sm">
        <div class="max-w-7xl mx-auto px-6">
            <div class="mb-6 flex justify-center">
                <span class="text-2xl font-black tracking-tighter text-white opacity-80">Watio<span class="text-watio-cyan">.</span></span>
            </div>
            <p class="mb-4">
                &copy; 2026 Watio Energy. Berlin | São Paulo | Buenos Aires.
            </p>
            <div class="space-x-4">
                <a href="#" class="hover:text-white transition-colors">Privacidad</a>
                <a href="#" class="hover:text-white transition-colors">Términos</a>
                <a href="mailto:jvolcanes@watio.com.ar" class="hover:text-white transition-colors">Contacto</a>
            </div>
        </div>
    </footer>

    <!-- Motor de Traducción -->
    <script>
        const translations = {
            "es-AR": {
                navCTA: "Solicitar Demo",
                heroPre: "EL CPMS DISEÑADO PARA LATAM",
                heroTitle: "Resolvé la carga de vehículos eléctricos en tu edificio sin complicar las expensas.",
                heroSub: "Watio es el sistema operativo que automatiza el cobro, la medición y la gestión de cargadores en consorcios. Transparencia total para los vecinos, cero fricción para la administración.",
                heroCTA: "Solicitar Demo Gratuita",
                mockupTitle: "Panel del Administrador",
                mockupUnit: "Cochera 12 - Unidad 4B",
                mockupUnit2: "Cochera 05 - Unidad 1A",
                mockupTotal: "Total a liquidar (Mes)",
                probTitle: "El futuro eléctrico ya llegó al garaje. ¿Está preparado el consorcio?",
                prob1Title: 'Adiós al "Robo" de Energía',
                prob1Desc: "Evitá conflictos. Terminá con la incertidumbre de quién paga por la luz que consume cada vehículo en las cocheras.",
                prob2Title: "Cero Cálculos Manuales",
                prob2Desc: "Olvidate de planillas de Excel complejas. El sistema mide el consumo exacto de cada usuario de forma individual.",
                prob3Title: "Gestión Centralizada",
                prob3Desc: "Un único panel para monitorear todos los puntos de carga del edificio, sin importar la marca del cargador.",
                solTitle: "Infraestructura inteligente, cobro automatizado.",
                sol1Title: "Medición Precisa",
                sol1Desc: "Nos integramos con los cargadores de tu edificio para leer el consumo en tiempo real.",
                sol2Title: "Cobro Directo",
                sol2Desc: "El vecino paga exactamente lo que consume a través de nuestra plataforma (integración con métodos de pago locales).",
                sol3Title: "Liquidación Transparente",
                sol3Desc: "El consorcio recibe el dinero de la energía consumida directamente en su cuenta, listo para descontar de los gastos comunes.",
                ctaTitle: "La movilidad eléctrica no tiene por qué ser un dolor de cabeza.",
                ctaSub: "Dejanos la infraestructura a nosotros. Vos enfocate en administrar.",
                ctaBtn: "Hablar con un Asesor"
            },
            "pt-BR": {
                navCTA: "Agendar Demo",
                heroPre: "O CPMS PROJETADO PARA A AMÉRICA LATINA",
                heroTitle: "Resolva a recarga de veículos elétricos no seu prédio sem complicar a taxa condominial.",
                heroSub: "Watio é o sistema operacional que automatiza a cobrança, medição e gestão de carregadores em condomínios. Transparência total para os moradores, zero atrito para o síndico.",
                heroCTA: "Solicitar Demo Gratuita",
                mockupTitle: "Painel do Síndico",
                mockupUnit: "Vaga 12 - Apto 4B",
                mockupUnit2: "Vaga 05 - Apto 1A",
                mockupTotal: "Total a repassar (Mês)",
                probTitle: "O futuro elétrico já chegou à garagem. O condomínio está preparado?",
                prob1Title: 'Adeus ao "Roubo" de Energia',
                prob1Desc: "Evite conflitos. Acabe com a incerteza de quem paga pela luz consumida por cada veículo nas vagas.",
                prob2Title: "Zero Cálculos Manuais",
                prob2Desc: "Esqueça planilhas complexas. O sistema mede o consumo exato de cada usuário individualmente.",
                prob3Title: "Gestão Centralizada",
                prob3Desc: "Um painel único para monitorar todos os pontos de recarga do prédio, independente da marca do carregador.",
                solTitle: "Infraestrutura inteligente, cobrança automatizada.",
                sol1Title: "Medição Precisa",
                sol1Desc: "Nos integramos aos carregadores do seu prédio para ler o consumo em tempo real.",
                sol2Title: "Cobrança Direta",
                sol2Desc: "O morador paga exatamente o que consome através da nossa plataforma (integração com PIX e cartões).",
                sol3Title: "Liquidação Transparente",
                sol3Desc: "O condomínio recebe o valor da energia consumida diretamente na sua conta, pronto para abater nas despesas comuns.",
                ctaTitle: "A mobilidade elétrica não precisa ser uma dor de cabeça.",
                ctaSub: "Deixe a infraestrutura conosco. Você foca em administrar.",
                ctaBtn: "Falar com um Especialista"
            }
        };

        function setLanguage(lang) {
            document.documentElement.lang = lang;
            
            document.querySelectorAll('[data-i18n]').forEach(el => {
                const key = el.getAttribute('data-i18n');
                if (translations[lang] && translations[lang][key]) {
                    el.innerHTML = translations[lang][key];
                }
            });

            document.querySelectorAll('.lang-btn').forEach(btn => {
                btn.classList.remove('opacity-100', 'font-black', 'text-watio-charcoal');
                btn.classList.add('opacity-50');
                if(btn.dataset.lang === lang) {
                    btn.classList.remove('opacity-50');
                    btn.classList.add('opacity-100', 'font-black', 'text-watio-charcoal');
                }
            });
        }

        window.addEventListener('DOMContentLoaded', () => {
            const browserLang = navigator.language || navigator.userLanguage;
            let defaultLang = 'es-AR'; 
            
            if (browserLang.toLowerCase().includes('pt')) {
                defaultLang = 'pt-BR';
            }
            
            setLanguage(defaultLang);
        });
    </script>
</body>
</html>
